{
  "name": "scopic",
  "version": "1.7.0",
  "description": "Scopic - Legal AI assistant. Local-first via Ollama, with optional Anthropic/OpenAI/Gemini support.",
  "main": "src/main/index.js",
  "author": "Scopic",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --port 5173 --strictPort",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "start": "electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.11",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.scopic.legal",
    "productName": "Scopic",
    "artifactName": "${productName}.Setup.${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "src/main/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ezazahamad2003",
        "repo": "scopic"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "shortcutName": "Scopic"
    }
  }
}
